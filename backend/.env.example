# Server Configuration
PORT=8000
ENV=development
SERVICE_NAME=mdm_portal
SERVICE_VERSION=1.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=mdm_portal
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Ho_Chi_Minh
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=3

# JWT Configuration
JWT_SECRET=change-this-secret-in-production-min-32-chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_HOURS=12

# Logging Configuration
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=30
LOG_MAX_AGE_DAYS=90
LOG_COMPRESS=true

# Cookie Configuration
COOKIE_NAME=app_token
COOKIE_REFRESH_NAME=app_refresh
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
COOKIE_PATH=/

# Casbin Configuration
CASBIN_MODEL_PATH=configs/casbin_model.conf

# NanoCMD Configuration
NANOCMD_URL=http://localhost:9003
NANOCMD_USERNAME=nanocmd
NANOCMD_PASSWORD=nanocmd

# NanoMDM Configuration
NANOMDM_URL=http://localhost:9000
NANODEP_URL=http://localhost:9000
NANOMDM_USERNAME=nanomdm
NANOMDM_PASSWORD=nanomdm
NANODEP_USERNAME=depserver
NANODEP_PASSWORD=nanodep

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Seeding Configuration
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin
SEED_ADMIN_EMAIL=admin@thd.vn
